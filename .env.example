# Port the scheduler API listens on.
PORT=4500

# OPTIONAL default delivery target — used when a schedule omits its own `url`.
# Lets a single backend post just {name, fireAt, body}. For community-api this
# is the internal scheduled-callback endpoint:
#   DEFAULT_TARGET_URL=http://localhost:3333/api/internal/feed/publish-scheduled
DEFAULT_TARGET_URL=

# OPTIONAL default Authorization header sent when a schedule omits one.
# For community-api this must equal the backend's INTERNAL_API_SECRET:
#   DEFAULT_AUTH_HEADER=Bearer your-internal-secret
DEFAULT_AUTH_HEADER=

# How often the poll loop checks for due schedules (ms). 1s is plenty.
POLL_INTERVAL_MS=1000

# Delivery retry policy (mimics SQS visibility-timeout retries + DLQ).
MAX_ATTEMPTS=5
RETRY_BACKOFF_MS=5000
DELIVER_TIMEOUT_MS=15000

# Durable store file (survives restarts). Atomic writes.
STORE_FILE=./data/store.json
